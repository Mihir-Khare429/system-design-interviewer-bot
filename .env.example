# ── Recall.ai ──────────────────────────────────────────────────────────────────
# Get a free developer key at https://www.recall.ai/
RECALL_API_KEY=your_recall_api_key_here

# ── OpenAI (optional if using Ollama + Kokoro) ─────────────────────────────────
# Only needed if LLM_BASE_URL / TTS_BASE_URL point to OpenAI.
OPENAI_API_KEY=your_openai_api_key_here

# ── LLM backend ────────────────────────────────────────────────────────────────
# To use Ollama locally: install Ollama, run `ollama pull llama3.2`, then set:
#   LLM_BASE_URL=http://host.docker.internal:11434/v1
#   LLM_MODEL=llama3.2
#   LLM_VISION_MODEL=llava   (for whiteboard analysis)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_VISION_MODEL=gpt-4o

# ── TTS backend ────────────────────────────────────────────────────────────────
# Kokoro runs as a Docker service — no API key needed.
# Voices: af_bella, af_sarah, am_adam, am_michael, bf_emma, bm_george
# To use Kokoro: TTS_BASE_URL=http://kokoro:8880/v1  TTS_VOICE=af_bella
# To use OpenAI: TTS_BASE_URL=https://api.openai.com/v1  TTS_VOICE=onyx
TTS_BASE_URL=http://kokoro:8880/v1
TTS_VOICE=af_bella

# ── ngrok ──────────────────────────────────────────────────────────────────────
# Free authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# Without this, ngrok still works but tunnels are ephemeral and limited.
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ── App ────────────────────────────────────────────────────────────────────────
PORT=8000

# Public URL that Recall.ai will use to POST webhooks and fetch TTS audio.
# Step 1: start `docker compose up` — note the ngrok URL printed in its logs
#         (or visit http://localhost:4040 to see it).
# Step 2: paste it here and restart:  docker compose restart app
# Example: https://abc123.ngrok-free.app
WEBHOOK_BASE_URL=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app

# Optional: change the bot's display name inside the meeting
BOT_PERSONA_NAME=System Design Interviewer

# ── SaaS (auth, billing, DB) ───────────────────────────────────────────────────
# Local dev defaults — change in production.
DATABASE_URL=sqlite+aiosqlite:///./sdi.db
JWT_SECRET=dev-secret-change-me-in-prod
FRONTEND_ORIGIN=http://localhost:3000

# Plan limits
FREE_MONTHLY_INTERVIEWS=3
PRO_MONTHLY_INTERVIEWS=1000

# Stripe (test mode). Leave blank to disable billing endpoints; pricing page will still
# render but the upgrade button returns 503.
# - Get keys at https://dashboard.stripe.com/test/apikeys
# - Create a $19/mo recurring price and put its price_id in STRIPE_PRICE_ID_PRO
# - For local webhook testing: `stripe listen --forward-to localhost:8000/api/billing/webhook`
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?upgraded=1
STRIPE_CANCEL_URL=http://localhost:3000/pricing
